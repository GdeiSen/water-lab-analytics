{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Water Lab Analytics",
  "version": "1.0.0",
  "identifier": "com.waterlab.analytics",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Water Lab Analytics",
        "label": "main",
        "width": 1560,
        "height": 980,
        "resizable": true,
        "center": true,
        "minWidth": 1024,
        "minHeight": 768
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/icon.png"
    ]
  }
}
